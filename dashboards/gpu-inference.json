        {
          "expr": "avg(DCGM_FI_DEV_GPU_UTIL)",
          "legendFormat": "now",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },

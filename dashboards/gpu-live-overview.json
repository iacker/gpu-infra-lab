{
  "title": "GPU Live Overview — vLLM + DCGM",
  "uid": "gpu-live-overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["gpu", "vllm", "dcgm", "live"],
  "timezone": "browser",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GPU util now (%)",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "avg(DCGM_FI_DEV_GPU_UTIL)", "legendFormat": "now"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU power now (W)",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "avg(DCGM_FI_DEV_POWER_USAGE)", "legendFormat": "now"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GPU power peak 15m (W)",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "max(max_over_time(DCGM_FI_DEV_POWER_USAGE[15m]))", "legendFormat": "peak"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Generated tokens total",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(vllm:generation_tokens_total)", "legendFormat": "tokens"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Prompt throughput now (tok/s)",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 5},
      "targets": [{"expr": "sum(vllm:avg_prompt_throughput_toks_per_s)", "legendFormat": "prompt"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Generation throughput now (tok/s)",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 5},
      "targets": [{"expr": "sum(vllm:avg_generation_throughput_toks_per_s)", "legendFormat": "gen"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "TTFT p95 (s, 5m)",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 5},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "GPU KV cache used (%)",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 5},
      "targets": [{"expr": "avg(vllm:gpu_cache_usage_perc)", "legendFormat": "cache"}],
      "options": {"reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""}, "orientation": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GPU utilization over time (%)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [{"expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "gpu {{gpu}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GPU power over time (W)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [{"expr": "DCGM_FI_DEV_POWER_USAGE", "legendFormat": "gpu {{gpu}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "TTFT p50 / p95 over time (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Prompt vs generation throughput (tok/s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "targets": [
        {"expr": "sum(vllm:avg_prompt_throughput_toks_per_s)", "legendFormat": "prompt"},
        {"expr": "sum(vllm:avg_generation_throughput_toks_per_s)", "legendFormat": "generation"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Running vs waiting requests",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "targets": [
        {"expr": "sum(vllm:num_requests_running)", "legendFormat": "running"},
        {"expr": "sum(vllm:num_requests_waiting)", "legendFormat": "waiting"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "VRAM used (MiB)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "targets": [{"expr": "DCGM_FI_DEV_FB_USED", "legendFormat": "gpu {{gpu}}"}],
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    }
  ]
}
